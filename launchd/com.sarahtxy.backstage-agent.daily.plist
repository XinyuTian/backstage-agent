<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.sarahtxy.backstage-agent.daily</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/sarahtxy/dev/backstage_agent/scripts/daily_scan.sh</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>9</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/sarahtxy/dev/backstage_agent/logs/daily-scan.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/sarahtxy/dev/backstage_agent/logs/daily-scan.err.log</string>
</dict>
</plist>
