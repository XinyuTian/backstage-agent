<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.sarahtxy.backstage-agent.daily</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd /Users/sarahtxy/Documents/backstage &amp;&amp; mkdir -p logs &amp;&amp; echo "[$(/bin/date '+%Y-%m-%d %H:%M:%S %Z')] Starting daily Backstage scan" &amp;&amp; /Users/sarahtxy/Documents/backstage/.venv/bin/python -m backstage_agent.cli scan --days 1 --limit 25 &amp;&amp; echo "[$(/bin/date '+%Y-%m-%d %H:%M:%S %Z')] Finished daily Backstage scan"</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>9</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/sarahtxy/Documents/backstage/logs/daily-scan.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/sarahtxy/Documents/backstage/logs/daily-scan.err.log</string>
</dict>
</plist>
